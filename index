            color: #ffd966;
            padding: 8px 22px;
            border-radius: 40px;
        }
        .info-mapel {
            background: #ffe4b5;
            padding: 6px 16px;
            border-radius: 30px;
        }
        .soal-pertanyaan {
            background: #fffbf0;
            border: 3px solid #ca9e5a;
            border-radius: 40px;
            padding: 28px 24px;
            font-size: 1.5rem;
            font-weight: 600;
            color: #1f3a57;
            margin: 20px 0;
            text-align: center;
            box-shadow: inset 0 0 0 2px #fbe9c3;
