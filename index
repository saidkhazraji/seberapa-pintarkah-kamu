        pageKelas.style.display = 'none';
        pageSoal.style.display = 'block';
        pageHasil.style.display = 'none';
        tampilkanSoal();
    }

    function tampilkanSoal() {
        const s = soalList[indeks];
        soalPertanyaan.innerText = s.pertanyaan;
        let html = '';
        for (let i = 0; i < 4; i++) {
            let checked = (jawabanUser[indeks] === i) ? 'checked' : '';
            html += `
                <div class="pilihan-item ${checked ? 'selected' : ''}" data-index="${i}">
                    <input type="radio" name="pilihan" value="${i}" id="opt${i}" ${checked}>
                    <label class="pilihan-label" for="opt${i}">${s.pilihan[i]}</label>
                </div>
            `;
        }
        pilihanContainer.innerHTML = html;
        document.querySelectorAll('.pilihan-item').forEach(item => {
            item.addEventListener('click', function(e) {
                let radio = this.querySelector('input');
                radio.checked = true;
                document.querySelectorAll('.pilihan-item').forEach(pi => pi.classList.remove('selected'));
                this.classList.add('selected');
                jawabanUser[indeks] = parseInt(radio.value);
            });
        });

        soalCounter.innerText = `${indeks+1}/10`;
        prevSoal.disabled = (indeks === 0);
        if (indeks === 9) {
            nextSoal.style.display = 'none';
            submitSoal.style.display = 'inline-block';
        } else {
            nextSoal.style.display = 'inline-block';
            submitSoal.style.display = 'none';
        }
    }

    function nextSoalFn() { if (indeks < 9) { indeks++; tampilkanSoal(); } }
    function prevSoalFn() { if (indeks > 0) { indeks--; tampilkanSoal(); } }

    function hitungSkor() {
        let benar = 0;
        for (let i = 0; i < soalList.length; i++) {
            if (jawabanUser[i] === soalList[i].jawaban) benar++;
        }
        let skor = benar * 10;
        nilaiAkhir.innerText = skor;

        let reviewHtml = '<h3>📋 Soal yang salah:</h3>';
        let adaSalah = false;
        for (let i = 0; i < soalList.length; i++) {
            if (jawabanUser[i] !== soalList[i].jawaban) {
                adaSalah = true;
                let soal = soalList[i];
                let jawabUser = jawabanUser[i] !== null ? soal.pilihan[jawabanUser[i]] : '(Tidak dijawab)';
                let jawabBenar = soal.pilihan[soal.jawaban];
                reviewHtml += `
                    <div class="review-item">
                        <div class="review-pertanyaan">${i+1}. ${soal.pertanyaan}</div>
                        <div class="review-jawaban">❌ Jawabanmu: ${jawabUser}</div>
                        <div class="review-jawaban" style="background:#cfebcf;">✅ Jawaban benar: ${jawabBenar}</div>
                    </div>
                `;
            }
        }
        if (!adaSalah) reviewHtml += '<p style="text-align:center; font-size:1.2rem;">🎉 Selamat, semua jawaban benar!</p>';
        reviewContainer.innerHTML = reviewHtml;

        pageSoal.style.display = 'none';
        pageHasil.style.display = 'block';
    }

