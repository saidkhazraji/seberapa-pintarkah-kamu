</head>
<body>
<div class="game-container">
    <div class="card">
        <h1>🤔 SEBERAPA PINTARKAH KAMU?</h1>

        <!-- HALAMAN PILIH MAPEL (8 mapel) -->
        <div id="pageMapel">
            <h2>📚 Pilih Mata Pelajaran</h2>
            <div class="button-grid">
                <button class="btn mapel-btn" data-mapel="matematika">🧮 Matematika</button>
                <button class="btn mapel-btn" data-mapel="ips">🌏 IPS</button>
