        .pilihan-container {
            display: flex;
            flex-direction: column;
            gap: 12px;
            margin: 20px 0;
        }
        .pilihan-item {
            background: white;
            border: 2px solid #a58e6d;
            border-radius: 60px;
            padding: 14px 24px;
            display: flex;
            align-items: center;
            cursor: pointer;
            box-shadow: 0 4px 0 #8b764f;
