            <div class="hasil-box">
                <h2>🎉 Skor Akhir</h2>
                <div class="nilai-angka" id="nilaiAkhir">0</div>
                <div class="review-soal" id="reviewContainer"></div>
                <button class="btn primary btn-restart" id="restartGame">🔄 Coba Lagi</button>
            </div>
        </div>
    </div>
    <div class="footer">✨ 10 soal berbeda setiap main | review soal salah</div>
</div>

