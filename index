    // ============ GENERATE SOAL DENGAN SHUFFLE ============
    function generateSoal() {
        let bank = getBankSoal();
        // Acak urutan bank (shuffle)
        for (let i = bank.length - 1; i > 0; i--) {
            const j = Math.floor(Math.random() * (i + 1));
            [bank[i], bank[j]] = [bank[j], bank[i]];
        }
        // Ambil 10 soal pertama (jika bank kurang dari 10, ulangi dengan random, tapi kita pastikan >=10)
        let soal = [];
        for (let i = 0; i < 10; i++) {
            // Jika bank lebih dari 10, kita sudah shuffle dan ambil 10 pertama
            // Jika bank kurang (tidak mungkin karena semua >=10), kita bisa ambil modulo, tapi kita hindari
            soal.push({
                pertanyaan: bank[i].q,
                pilihan: bank[i].p,
                jawaban: bank[i].j
            });
        }
        return soal;
    }

    // ============ MULAI GAME ============
    function mulaiGame() {
        soalList = generateSoal();
        jawabanUser = new Array(10).fill(null);
        indeks = 0;

        let namaMapel = {
            matematika: 'Matematika', ips: 'IPS', ipa: 'IPA', seni: 'Seni Rupa',
            pkn: 'Pancasila', bindo: 'B. Indonesia', binggris: 'B. Inggris', sejarah: 'Sejarah'
        }[mapel];
