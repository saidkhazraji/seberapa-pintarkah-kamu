                <button class="btn mapel-btn" data-mapel="sejarah">🏛️ Sejarah</button>
            </div>
        </div>

        <!-- HALAMAN TINGKAT -->
        <div id="pageTingkat" style="display: none;">
            <h2>🏫 Pilih Tingkat</h2>
            <div class="button-grid">
                <button class="btn tingkat-btn" data-tingkat="tk">TK</button>
                <button class="btn tingkat-btn" data-tingkat="sd">SD</button>
                <button class="btn tingkat-btn" data-tingkat="smp">SMP</button>
                <button class="btn tingkat-btn" data-tingkat="sma">SMA</button>
            </div>
            <div style="text-align: center; margin-top: 20px;">
                <button class="btn small" id="backToMapel">⬅ Kembali</button>
            </div>
        </div>

        <!-- HALAMAN KELAS -->
        <div id="pageKelas" style="display: none;">
            <h2 id="kelasTitle">📌 Pilih Kelas</h2>
            <div id="kelasButtons" class="kelas-container"></div>
            <div style="text-align: center;">
                <button class="btn small" id="backToTingkat">⬅ Kembali</button>
            </div>
        </div>

        <!-- HALAMAN SOAL -->
        <div id="pageSoal" style="display: none;">
