                <span class="soal-nomor" id="soalCounter">1/10</span>
                <span class="info-mapel" id="infoMapelTingkat"></span>
            </div>
            <div id="soalPertanyaan" class="soal-pertanyaan">Memuat soal...</div>
            <div id="pilihanContainer" class="pilihan-container"></div>
            <div class="nav-buttons">
                <button class="btn small" id="prevSoal" disabled>◀ Sebelumnya</button>
                <button class="btn small" id="nextSoal">Selanjutnya ▶</button>
                <button class="btn small primary" id="submitSoal" style="display: none;">✅ Selesai</button>
            </div>
        </div>

