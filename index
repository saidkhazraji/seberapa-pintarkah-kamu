        }
        h1 {
            color: #1f3a57;
            font-weight: 800;
            font-size: 2.6rem;
            margin: 0 0 10px;
            text-align: center;
            text-shadow: 4px 4px 0 #ffc107;
            letter-spacing: 2px;
            word-break: break-word;
        }
        h2 {
            color: #1f3a57;
            font-weight: 700;
            font-size: 1.8rem;
            margin: 10px 0 20px;
            text-align: center;
            text-shadow: 2px 2px 0 #ffb300;
        }
        .button-grid {
            display: flex;
            flex-wrap: wrap;
            gap: 12px;
            justify-content: center;
            margin: 20px 0;
        }
