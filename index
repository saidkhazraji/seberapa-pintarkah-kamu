            background: #fedb86;
            border: none;
            color: #1f3a57;
            font-weight: 700;
            font-size: 1.2rem;
            padding: 14px 22px;
            border-radius: 60px;
            box-shadow: 0 6px 0 #b2892c, 0 8px 16px rgba(0,0,0,0.3);
            cursor: pointer;
            transition: 0.07s;
            border: 1px solid #ffc107;
            min-width: 120px;
        }
        .btn:active {
            transform: translateY(6px);
            box-shadow: 0 2px 0 #b2892c;
        }
        .btn.small {
            font-size: 1rem;
            padding: 10px 16px;
            min-width: 80px;
        }
        .btn.primary {
            background: #2d5a9c;
            color: white;
            box-shadow: 0 6px 0 #1a2f4e;
        }
        .kelas-container {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            justify-content: center;
            margin: 20px 0;
        }
