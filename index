            background: #c0dbfa;
            border: 2px solid #24548f;
            color: #09223b;
            font-weight: 600;
            font-size: 1.2rem;
            padding: 12px 20px;
            border-radius: 50px;
            min-width: 90px;
            cursor: pointer;
            transition: 0.1s;
